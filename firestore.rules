rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 問題：每位老師只能改自己的題目，但所有登入者都能讀（學生掃 QR 要看題目）
    match /questions/{questionId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.teacherId == request.auth.uid
                    && request.resource.data.keys().hasAll(['imageUrl', 'options', 'active', 'teacherId', 'createdAt', 'expiresAt', 'roomCode']);

      // owner 才能改；teacherId 與 roomCode 不可被改寫；
      // 允許更新 votingEndsAt（倒數計時器）、requireIdentity、active、correctAnswer、showAnswer
      allow update: if request.auth != null
                    && resource.data.teacherId == request.auth.uid
                    && request.resource.data.teacherId == resource.data.teacherId
                    && request.resource.data.roomCode == resource.data.roomCode;

      allow delete: if request.auth != null
                    && resource.data.teacherId == request.auth.uid;
    }

    // 投票：任何登入者可寫入自己的票；read 公開（投票統計需要）；
    // 刪除限定該題的 owner（用於 resetVotes）；不允許改票
    match /votes/{voteId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['questionId', 'optionIndex', 'userId', 'timestamp'])
                    && (!('voterName' in request.resource.data) || request.resource.data.voterName.size() <= 30)
                    && (!('voterSeat' in request.resource.data) || request.resource.data.voterSeat.size() <= 10);

      allow update: if false;

      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/questions/$(resource.data.questionId)).data.teacherId == request.auth.uid;
    }

    // 表情反饋（彈幕風格）：所有登入者可讀，本人才能寫；不可改、不可刪
    match /reactions/{rid} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['questionId', 'emoji', 'userId', 'createdAt'])
                    && request.resource.data.emoji.size() <= 8;

      allow update: if false;
      allow delete: if false;
    }

    // 其他 collection 一律拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
