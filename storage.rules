rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 題目圖片：路徑 questions/{teacherId}/{filename}
    // - read 公開（學生不用登入也能看題目圖；referrer 限制由 GCP API key 把關）
    // - write 限本人寫到自己 teacherId 的目錄，且檔案 < 800KB image/* 類型
    match /questions/{teacherId}/{filename} {
      allow read: if true;

      allow write: if request.auth != null
                   && request.auth.uid == teacherId
                   && request.resource.size < 800 * 1024
                   && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
                    && request.auth.uid == teacherId;
    }

    // 其他路徑一律拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
